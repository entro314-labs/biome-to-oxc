{
  "name": "biome-to-oxc",
  "version": "0.5.2",
  "description": "Migrate from Biome to Oxc ecosystem (oxlint + oxfmt) - Exhaustive, cutting-edge, with all experimental features",
  "keywords": [
    "biome",
    "formatter",
    "linter",
    "migration",
    "oxc",
    "oxfmt",
    "oxlint"
  ],
  "license": "MIT",
  "author": "Dominikos Pritis",
  "repository": {
    "type": "git",
    "url": "https://github.com/entro314-labs/biome-to-oxc"
  },
  "bin": {
    "biome-to-oxc": "./dist/bin/biome-to-oxc.mjs"
  },
  "files": [
    "README.md",
    "dist/*"
  ],
  "type": "module",
  "exports": {
    "types": "./dist/src/index.d.mts",
    "import": "./dist/src/index.mjs"
  },
  "scripts": {
    "test": "vitest",
    "lint": "oxlint",
    "format": "oxfmt",
    "check": "oxlint && oxfmt --check",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "jsonc-parser": "^3.3.1",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.0",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "oxlint-tsgolint": "^0.11.4",
    "tsdown": "0.20.1",
    "typescript": "^5.9.3",
    "vitest": "beta"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.2"
}
